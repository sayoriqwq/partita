{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "workspaces": {
    ".": {
      "entry": [
        "bin/partita.ts"
      ],
      "project": [
        "bin/**/*.ts",
        "src/**/*.ts",
        "tests/**/*.ts"
      ]
    },
    "packages/generic-projection": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    }
  },
  "ignoreDependencies": [
    "@effect/tsgo"
  ]
}
